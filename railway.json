{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "services": [
    {
      "name": "browser-bridge",
      "source": {
        "repo": "https://github.com/Christian-Starcke/browser-capable-node-openclaw"
      }
    }
  ]
}
